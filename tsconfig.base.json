{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@msvg/core": ["packages/core/src/index.ts"],
      "@msvg/svg": ["packages/svg/src/index.ts"],
      "@msvg/remark": ["packages/remark/src/index.ts"],
      "@msvg/markdown-it": ["packages/markdown-it/src/index.ts"],
      "@msvg/astro": ["packages/astro/src/index.ts"],
      "@msvg/cli": ["packages/cli/src/index.ts"]
    },
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": false
  }
}
