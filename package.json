{
  "name": "msvg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:snapshots": "npm run test:snapshots --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "assets:generate": "node scripts/generate-readme-assets.mjs",
    "test:report": "npm run test:report --workspaces --if-present",
    "quality:report": "npm run test:report && node scripts/quality-report.mjs",
    "verify": "npm run check && npm test && npm run test:coverage && npm run test:snapshots && npm run test:integration && npm run test:e2e && npm run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
