{
  "name": "@markdown-utils/msvg-cli",
  "version": "0.2.0",
  "description": "MSVG command-line interface",
  "license": "MIT",
  "author": "Kristyan Carvalho",
  "homepage": "https://github.com/kristyancarvalho/msvg#readme",
  "bugs": {
    "url": "https://github.com/kristyancarvalho/msvg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristyancarvalho/msvg.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "markdown",
    "svg",
    "diagram",
    "yaml",
    "documentation",
    "technical-writing",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "msvg": "dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --coverage --reporter=json --outputFile=vitest-report.json",
    "test:snapshots": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@markdown-utils/msvg-core": "^0.2.0",
    "@markdown-utils/msvg-svg": "^0.2.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  }
}
