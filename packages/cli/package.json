{
  "name": "@msvg/cli",
  "version": "0.1.0",
  "description": "MSVG command-line interface",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "msvg": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts src/main.ts --format esm --dts --out-dir dist --clean",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --coverage --reporter=json --outputFile=vitest-report.json",
    "test:snapshots": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@msvg/core": "^0.1.0",
    "@msvg/svg": "^0.1.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  }
}
