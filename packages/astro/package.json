{
  "name": "@msvg/astro",
  "version": "0.1.0",
  "description": "MSVG Astro integration",
  "license": "MIT",
  "author": "Kristyan Carvalho",
  "homepage": "https://github.com/kristyancarvalho/msvg#readme",
  "bugs": {
    "url": "https://github.com/kristyancarvalho/msvg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristyancarvalho/msvg.git",
    "directory": "packages/astro"
  },
  "keywords": [
    "markdown",
    "svg",
    "diagram",
    "yaml",
    "documentation",
    "technical-writing",
    "astro",
    "astro-integration"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --coverage --reporter=json --outputFile=vitest-report.json",
    "test:integration": "vitest run --reporter=verbose",
    "test:e2e": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@msvg/remark": "^0.1.0"
  },
  "peerDependencies": {
    "astro": ">=4"
  },
  "devDependencies": {
    "astro": "^4.11.0"
  }
}
