{
  "name": "@msvg/svg",
  "version": "0.0.0",
  "description": "MSVG SVG layout engine and renderer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:snapshots": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@msvg/core": "*"
  }
}
